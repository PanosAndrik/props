generator client {

  provider = "prisma-client-js"

}



datasource db {

  provider = "sqlite"

  url      = env("DATABASE_URL")

}



enum Role {

  USER

  ADMIN

}



enum ReviewStatus {

  PENDING

  APPROVED

  REJECTED

}



model User {

  id           String   @id @default(cuid())

  email        String   @unique

  name         String?

  passwordHash String

  role         Role     @default(USER)

  createdAt    DateTime @default(now())

  updatedAt    DateTime @updatedAt

  reviews      Review[]

  favorites    Favorite[]

  affiliateClicks AffiliateClick[]

}



model PropFirm {

  id              String   @id @default(cuid())

  name            String

  slug            String   @unique

  description     String?

  longOverview    String?

  websiteUrl      String?

  affiliateUrl    String?

  discountCode    String?

  discountPercent Int?

  logoUrl         String?

  countryCode     String?

  ceoName         String?

  foundedAt       DateTime?

  category        String   @default("forex")

  assetTypes      String   @default("forex,crypto")

  platforms       String   @default("")

  profitSplit     String?

  maxDrawdown     String?

  drawdownTypes   String?

  minFee          Float?

  maxAllocation   String?

  startingPrice   String?

  payoutSpeed     String?

  pros            String?

  cons            String?

  rankOrder       Int      @default(999)

  isNew           Boolean  @default(false)

  featured        Boolean  @default(false)

  published       Boolean  @default(true)

  newsTrading     Boolean  @default(false)

  weekendHolding  Boolean  @default(false)

  expertAdvisors  Boolean  @default(false)

  copyTrading     Boolean  @default(false)

  noTimeLimit     Boolean  @default(false)

  consistencyRule Boolean  @default(false)

  instantFunded   Boolean  @default(false)

  brandColor      String?

  showInOffers    Boolean  @default(false)

  createdAt       DateTime @default(now())

  updatedAt       DateTime @updatedAt

  reviews         Review[]

  challenges      FirmChallenge[]

  favorites       Favorite[]

  affiliateClicks AffiliateClick[]

}



model FirmChallenge {

  id           String   @id @default(cuid())

  firmId       String

  firm         PropFirm @relation(fields: [firmId], references: [id], onDelete: Cascade)

  name         String

  accountSize  String?

  price        Float?

  profitTarget String?

  maxDrawdown  String?

  profitSplit  String?

  published    Boolean  @default(true)

  sortOrder    Int      @default(0)

  createdAt    DateTime @default(now())

  updatedAt    DateTime @updatedAt



  @@index([firmId, published])

}



model Review {

  id        String       @id @default(cuid())

  rating    Int

  title     String?

  body      String

  status    ReviewStatus @default(PENDING)

  userId    String

  firmId    String

  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  firm      PropFirm     @relation(fields: [firmId], references: [id], onDelete: Cascade)

  createdAt DateTime     @default(now())

  updatedAt DateTime     @updatedAt



  @@unique([userId, firmId])

  @@index([firmId, status])

  @@index([userId])

}



model AffiliateClick {

  id              String   @id @default(cuid())

  firmId          String

  firm            PropFirm @relation(fields: [firmId], references: [id], onDelete: Cascade)

  userId          String?

  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  source          String

  destinationUrl  String

  createdAt       DateTime @default(now())



  @@index([firmId, createdAt])

  @@index([createdAt])

  @@index([source])

}



model Favorite {

  id        String   @id @default(cuid())

  userId    String

  firmId    String

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  firm      PropFirm @relation(fields: [firmId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())



  @@unique([userId, firmId])

  @@index([userId])

}



model BlogPost {

  id          String    @id @default(cuid())

  title       String

  slug        String    @unique

  excerpt     String?

  content     String

  coverImage  String?

  category    String?

  readTimeMinutes Int?

  difficulty  String?

  published   Boolean   @default(false)

  publishedAt DateTime?

  createdAt   DateTime  @default(now())

  updatedAt   DateTime  @updatedAt

}



model SiteSettings {

  id               String   @id @default("default")

  statFirmsValue   String   @default("200+")

  statFirmsLabel   String   @default("Prop firms")

  statTradersValue String   @default("50,000+")

  statTradersLabel String   @default("Traders helped")

  statCouponsValue String   @default("Exclusive")

  statCouponsLabel String   @default("Coupon codes")

  statFreeValue    String   @default("Free")

  statFreeLabel    String   @default("Always free")

  offersTitle      String   @default("Exclusive Offers")

  offersSubtitle   String?

  newsletterTitle    String   @default("Join 50,000+ traders on PropCompare")

  newsletterSubtitle String   @default("Create a free account to save firms to your list, write reviews, and track deals.")

  updatedAt        DateTime @updatedAt

}


