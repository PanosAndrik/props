# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# Visual Studio
.vs/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — keep .env.example in repo
.env
.env.local
.env.*.local

# uploaded images (keep folder via .gitkeep)
/public/uploads/blog/*
!/public/uploads/blog/.gitkeep
/public/uploads/firms/*
!/public/uploads/firms/.gitkeep

# local database
/prisma/*.db
/prisma/*.db-journal

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
